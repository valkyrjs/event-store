{
  "deno.enable": true,
  "deno.lint": false,
  "editor.formatOnSave": true,
  "eslint.nodePath": "./.lint/node_modules",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "[typescript]": { 
    "editor.defaultFormatter": "denoland.vscode-deno" 
  },
  "json.schemas": [
    {
      "fileMatch": ["/**/events/*.json"],
      "url": "./schemas/event.json"
    }
  ],
}